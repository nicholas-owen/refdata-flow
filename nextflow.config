params {
    // Input CSV file (generated by bin/resolve.py)
    input = 'requests_resolved.csv'
    
    // Output directory (can be overridden via command line: --outdir /path/to/storage)
    outdir = 'data/references'
}

profiles {
    standard {
        process.executor = 'local'
    }
    slurm {
        process.executor = 'slurm'
    }
    docker {
        docker.enabled = true
        // Note: The user may need to build a custom docker image or use a generic one
        // Here we use a biocontainer with genomepy
        process.container = 'quay.io/biocontainers/genomepy:0.16.1--pyhdfd78af_0' 
    }
    conda {
        conda.enabled = true
        process.conda = 'bioconda::genomepy'
    }
}
